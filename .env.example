# Optional env for future use (Phase 2+).
# No secrets required for Phase 1 MVP.

# Google Analytics (GA4). Set to your measurement ID, or leave unset to disable.
# Example: NEXT_PUBLIC_GA_MEASUREMENT_ID=G-6Y49J37KJH
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity. Set to your Clarity Project ID, or leave unset to disable.
# Example: NEXT_PUBLIC_CLARITY_PROJECT_ID=abcd1234ef
# NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ---- Self-evaluating telemetry + PR automation (optional) ----
#
# Storage for first-party telemetry aggregates.
# If deploying on Vercel, add Vercel KV and these will be auto-populated:
# KV_URL, KV_REST_API_URL, KV_REST_API_TOKEN, KV_REST_API_READ_ONLY_TOKEN

# Protect admin + PR-generation endpoints.
# Example: ADMIN_TOKEN=super-secret-long-random
# ADMIN_TOKEN=

# GitHub App (for creating PRs). Keep these server-side only (do NOT prefix with NEXT_PUBLIC_).
# Example:
# GITHUB_APP_ID=123456
# GITHUB_APP_INSTALLATION_ID=12345678
# GITHUB_APP_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_REPO_OWNER=your-org-or-user
# GITHUB_REPO_NAME=your-repo
# GITHUB_BASE_BRANCH=main
# GITHUB_APP_ID=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_PRIVATE_KEY_PEM=
# GITHUB_REPO_OWNER=
# GITHUB_REPO_NAME=
# GITHUB_BASE_BRANCH=
